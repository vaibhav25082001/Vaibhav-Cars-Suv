generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CarType {
  Sedan
  SUV
  EV
  Hybrid
  Coupe
  MPV
  Hatch
}

enum FuelType {
  Petrol
  Diesel
  Electric
  Hybrid
}

enum InventoryStatus {
  Available
  Sold
  Reserved
  InTransit
}

enum ConfigurationStatus {
  Draft
  QuoteSent
  Converted
}

enum FinanceType {
  Cash
  Loan
}

enum CustomerTag {
  VIP
  Regular
  Problematic
  ColdLead
}

enum TestDriveStatus {
  Scheduled
  Completed
  Cancelled
  NoShow
}

enum ServiceBookingStatus {
  Booked
  Received
  InProgress
  QualityCheck
  Done
  Cancelled
}

enum JobItemType {
  Labour
  Part
}

enum PaymentType {
  Cash
  Loan
  PartPayment
}

enum EmiStatus {
  Paid
  Due
  Overdue
}

enum ExpenseCategory {
  Rent
  Salary
  Marketing
  Utilities
  Other
}

enum EmployeeRole {
  SalesExecutive
  ServiceStaff
  ShowroomManager
  FinanceExecutive
  SupportAgent
  SupportSupervisor
  Admin
}

enum AttendanceStatus {
  Present
  Absent
  HalfDay
  Leave
}

enum LeaveType {
  Earned
  Sick
  Casual
}

enum RequestStatus {
  Pending
  Approved
  Rejected
}

enum LeadSource {
  WalkIn
  Online
  Referral
  Campaign
}

enum LeadStage {
  Inquiry
  TestDriveScheduled
  Negotiation
  ClosedWon
  ClosedLost
}

enum LeadPriority {
  Hot
  Warm
  Cold
}

enum InteractionType {
  Call
  Meeting
  WhatsApp
  Email
}

enum TicketIssueType {
  DeliveryDelay
  ServiceQuality
  EMIIssue
  Insurance
  Breakdown
  FeatureIssue
  General
}

enum TicketPriority {
  Urgent
  High
  Normal
  Low
}

enum TicketStatus {
  Open
  InProgress
  Escalated
  Resolved
  Closed
}

enum Sentiment {
  Angry
  Neutral
  Happy
}

enum TicketChannel {
  Web
  App
  Phone
  Email
  Chat
}

enum SenderType {
  Customer
  Agent
}

enum KbCategory {
  Warranty
  EMI
  Service
  Insurance
  Delivery
  Technical
  General
}

enum JobType {
  FullTime
  PartTime
  Intern
}

enum ApplicationStatus {
  Applied
  Shortlisted
  InterviewScheduled
  Hired
  Rejected
}

enum ActivityActionType {
  PageView
  Wishlist
  Booking
  Purchase
  Chat
}

enum PipelineStatus {
  Success
  Failed
  Running
}

enum RecipientType {
  Customer
  Employee
}

model Customer {
  id                String                @id @default(cuid())
  name              String
  email             String                @unique
  phone             String                @unique
  city              String
  passwordHash      String                @map("password_hash")
  profilePhotoUrl   String?               @map("profile_photo_url")
  loyaltyPoints     Int                   @default(0) @map("loyalty_points")
  referralCode      String                @unique @map("referral_code")
  referredById      String?               @map("referred_by")
  tag               CustomerTag           @default(Regular)
  createdAt         DateTime              @default(now()) @map("created_at")
  lastLogin         DateTime?             @map("last_login")
  referredBy        Customer?             @relation("CustomerReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         Customer[]            @relation("CustomerReferrals")
  vehicles          CustomerVehicle[]
  wishlists         Wishlist[]
  configurations    CarConfiguration[]
  testDrives        TestDriveBooking[]
  serviceBookings   ServiceBooking[]
  purchases         Purchase[]
  emiPayments       EmiPayment[]
  leads             Lead[]
  supportTickets    SupportTicket[]
  activityLogs      CustomerActivityLog[]

  @@index([city])
  @@index([tag])
  @@map("customers")
}

model CustomerVehicle {
  id                 String           @id @default(cuid())
  customerId         String           @map("customer_id")
  carModelId         String           @map("car_model_id")
  vin                String           @unique
  registrationNumber String           @unique @map("registration_number")
  purchaseDate       DateTime         @map("purchase_date")
  purchasePrice      Decimal          @db.Decimal(12, 2) @map("purchase_price")
  insuranceCompany   String           @map("insurance_company")
  insuranceExpiry    DateTime         @map("insurance_expiry")
  nextServiceDue     DateTime         @map("next_service_due")
  color              String
  createdAt          DateTime         @default(now()) @map("created_at")
  customer           Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  carModel           CarModel         @relation(fields: [carModelId], references: [id])
  serviceBookings    ServiceBooking[]

  @@index([customerId])
  @@index([carModelId])
  @@index([nextServiceDue])
  @@map("customer_vehicles")
}

model CarModel {
  id                String              @id @default(cuid())
  name              String              @unique
  type              CarType
  price             Decimal             @db.Decimal(12, 2)
  engineCc          Int                 @map("engine_cc")
  bhp               Int
  torque            String
  fuelType          FuelType            @map("fuel_type")
  mileage           String
  rangeKm           Int?                @map("range_km")
  colorsAvailable   String[]            @map("colors_available")
  features          String[]
  imageUrls         String[]            @map("image_urls")
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  inventory         CarInventory[]
  configurations    CarConfiguration[]
  customerVehicles  CustomerVehicle[]
  wishlists         Wishlist[]
  testDrives        TestDriveBooking[]
  leads             Lead[]
  offers            Offer[]

  @@index([type])
  @@index([fuelType])
  @@index([price])
  @@index([isActive])
  @@map("car_models")
}

model CarInventory {
  id          String          @id @default(cuid())
  carModelId  String          @map("car_model_id")
  showroomId  String          @map("showroom_id")
  color       String
  vin         String          @unique
  status      InventoryStatus @default(Available)
  arrivalDate DateTime        @map("arrival_date")
  soldDate    DateTime?       @map("sold_date")
  createdAt   DateTime        @default(now()) @map("created_at")
  carModel    CarModel        @relation(fields: [carModelId], references: [id])
  showroom    Showroom        @relation(fields: [showroomId], references: [id])
  purchase    Purchase?

  @@index([carModelId])
  @@index([showroomId])
  @@index([status])
  @@index([arrivalDate])
  @@map("car_inventory")
}

model CarConfiguration {
  id             String              @id @default(cuid())
  customerId     String              @map("customer_id")
  carModelId     String              @map("car_model_id")
  selectedColor  String              @map("selected_color")
  interiorType   String              @map("interior_type")
  addons         String[]
  basePrice      Decimal             @db.Decimal(12, 2) @map("base_price")
  addonsPrice    Decimal             @db.Decimal(12, 2) @map("addons_price")
  gst            Decimal             @db.Decimal(12, 2)
  totalPrice     Decimal             @db.Decimal(12, 2) @map("total_price")
  financeType    FinanceType         @map("finance_type")
  loanTenure     Int?                @map("loan_tenure")
  loanRate       Decimal?            @db.Decimal(5, 2) @map("loan_rate")
  emiAmount      Decimal?            @db.Decimal(12, 2) @map("emi_amount")
  status         ConfigurationStatus @default(Draft)
  createdAt      DateTime            @default(now()) @map("created_at")
  customer       Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  carModel       CarModel            @relation(fields: [carModelId], references: [id])
  purchases      Purchase[]

  @@index([customerId])
  @@index([carModelId])
  @@index([status])
  @@map("car_configurations")
}

model Showroom {
  id                String                  @id @default(cuid())
  name              String
  city              String
  address           String
  pincode           String
  phone             String
  email             String                  @unique
  managerId         String?                 @unique @map("manager_id")
  googleMapsUrl     String                  @map("google_maps_url")
  isActive          Boolean                 @default(true) @map("is_active")
  createdAt         DateTime                @default(now()) @map("created_at")
  manager           Employee?               @relation("ShowroomManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees         Employee[]              @relation("EmployeeShowroom")
  targets           ShowroomTarget[]
  inventory         CarInventory[]
  testDrives        TestDriveBooking[]
  serviceBookings   ServiceBooking[]
  purchases         Purchase[]
  expenses          Expense[]
  dailySummaries    DailySalesSummary[]
  monthlySummaries  MonthlyRevenueSummary[]

  @@index([city])
  @@index([isActive])
  @@map("showrooms")
}

model ShowroomTarget {
  id              String   @id @default(cuid())
  showroomId      String   @map("showroom_id")
  month           Int
  year            Int
  salesTarget     Int      @map("sales_target")
  revenueTarget   Decimal  @db.Decimal(14, 2) @map("revenue_target")
  salesAchieved   Int      @default(0) @map("sales_achieved")
  revenueAchieved Decimal  @default(0) @db.Decimal(14, 2) @map("revenue_achieved")
  showroom        Showroom @relation(fields: [showroomId], references: [id], onDelete: Cascade)

  @@unique([showroomId, month, year])
  @@index([month, year])
  @@map("showroom_targets")
}

model Purchase {
  id                 String            @id @default(cuid())
  customerId         String            @map("customer_id")
  carInventoryId     String            @unique @map("car_inventory_id")
  carConfigurationId String?           @map("car_configuration_id")
  employeeId         String            @map("employee_id")
  showroomId         String            @map("showroom_id")
  invoiceNumber      String            @unique @map("invoice_number")
  purchaseDate       DateTime          @map("purchase_date")
  exShowroomPrice    Decimal           @db.Decimal(12, 2) @map("ex_showroom_price")
  rtoCharges         Decimal           @db.Decimal(12, 2) @map("rto_charges")
  insuranceAmount    Decimal           @db.Decimal(12, 2) @map("insurance_amount")
  accessoriesCost    Decimal           @db.Decimal(12, 2) @map("accessories_cost")
  gstAmount          Decimal           @db.Decimal(12, 2) @map("gst_amount")
  totalAmount        Decimal           @db.Decimal(12, 2) @map("total_amount")
  paymentType        PaymentType       @map("payment_type")
  loanAmount         Decimal?          @db.Decimal(12, 2) @map("loan_amount")
  loanTenure         Int?              @map("loan_tenure")
  loanRate           Decimal?          @db.Decimal(5, 2) @map("loan_rate")
  emiAmount          Decimal?          @db.Decimal(12, 2) @map("emi_amount")
  deliveryDate       DateTime          @map("delivery_date")
  invoicePdfUrl      String?           @map("invoice_pdf_url")
  createdAt          DateTime          @default(now()) @map("created_at")
  customer           Customer          @relation(fields: [customerId], references: [id])
  carInventory       CarInventory      @relation(fields: [carInventoryId], references: [id])
  carConfiguration   CarConfiguration? @relation(fields: [carConfigurationId], references: [id], onDelete: SetNull)
  employee           Employee          @relation(fields: [employeeId], references: [id])
  showroom           Showroom          @relation(fields: [showroomId], references: [id])
  emiPayments        EmiPayment[]

  @@index([customerId])
  @@index([employeeId])
  @@index([showroomId])
  @@index([purchaseDate])
  @@index([paymentType])
  @@map("purchases")
}

model EmiPayment {
  id               String    @id @default(cuid())
  purchaseId       String    @map("purchase_id")
  customerId       String    @map("customer_id")
  monthNumber      Int       @map("month_number")
  dueDate          DateTime  @map("due_date")
  paidDate         DateTime? @map("paid_date")
  principalAmount  Decimal   @db.Decimal(12, 2) @map("principal_amount")
  interestAmount   Decimal   @db.Decimal(12, 2) @map("interest_amount")
  emiAmount        Decimal   @db.Decimal(12, 2) @map("emi_amount")
  balanceRemaining Decimal   @db.Decimal(12, 2) @map("balance_remaining")
  status           EmiStatus @default(Due)
  createdAt        DateTime  @default(now()) @map("created_at")
  purchase         Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([purchaseId, monthNumber])
  @@index([customerId])
  @@index([dueDate])
  @@index([status])
  @@map("emi_payments")
}

model Expense {
  id          String          @id @default(cuid())
  showroomId  String          @map("showroom_id")
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  month       Int
  year        Int
  description String
  createdAt   DateTime        @default(now()) @map("created_at")
  showroom    Showroom        @relation(fields: [showroomId], references: [id], onDelete: Cascade)

  @@index([showroomId])
  @@index([month, year])
  @@index([category])
  @@map("expenses")
}

model TestDriveBooking {
  id                String          @id @default(cuid())
  customerId        String          @map("customer_id")
  carModelId        String          @map("car_model_id")
  showroomId        String          @map("showroom_id")
  employeeId        String?         @map("employee_id")
  bookingDate       DateTime        @map("booking_date")
  timeSlot          String          @map("time_slot")
  status            TestDriveStatus @default(Scheduled)
  postDriveFeedback String?         @map("post_drive_feedback")
  customerReaction  String?         @map("customer_reaction")
  bookingPdfUrl     String?         @map("booking_pdf_url")
  createdAt         DateTime        @default(now()) @map("created_at")
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  carModel          CarModel        @relation(fields: [carModelId], references: [id])
  showroom          Showroom        @relation(fields: [showroomId], references: [id])
  employee          Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([carModelId])
  @@index([showroomId])
  @@index([employeeId])
  @@index([bookingDate])
  @@index([status])
  @@map("test_drive_bookings")
}

model ServiceBooking {
  id                String               @id @default(cuid())
  customerId        String               @map("customer_id")
  customerVehicleId String               @map("customer_vehicle_id")
  showroomId        String               @map("showroom_id")
  mechanicId        String?              @map("mechanic_id")
  serviceType       String               @map("service_type")
  description       String
  bookingDate       DateTime             @map("booking_date")
  timeSlot          String               @map("time_slot")
  status            ServiceBookingStatus @default(Booked)
  estimatedCost     Decimal              @db.Decimal(12, 2) @map("estimated_cost")
  finalCost         Decimal?             @db.Decimal(12, 2) @map("final_cost")
  jobCardPdfUrl     String?              @map("job_card_pdf_url")
  createdAt         DateTime             @default(now()) @map("created_at")
  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerVehicle   CustomerVehicle      @relation(fields: [customerVehicleId], references: [id])
  showroom          Showroom             @relation(fields: [showroomId], references: [id])
  mechanic          Employee?            @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  jobItems          ServiceJobItem[]

  @@index([customerId])
  @@index([customerVehicleId])
  @@index([showroomId])
  @@index([mechanicId])
  @@index([bookingDate])
  @@index([status])
  @@map("service_bookings")
}

model ServiceJobItem {
  id                String         @id @default(cuid())
  serviceBookingId  String         @map("service_booking_id")
  itemDescription   String         @map("item_description")
  itemType          JobItemType     @map("item_type")
  quantity          Int
  unitPrice         Decimal        @db.Decimal(12, 2) @map("unit_price")
  totalPrice        Decimal        @db.Decimal(12, 2) @map("total_price")
  serviceBooking    ServiceBooking @relation(fields: [serviceBookingId], references: [id], onDelete: Cascade)

  @@index([serviceBookingId])
  @@index([itemType])
  @@map("service_job_items")
}

model Employee {
  id                    String             @id @default(cuid())
  name                  String
  email                 String             @unique
  phone                 String             @unique
  employeeCode          String             @unique @map("employee_code")
  role                  EmployeeRole
  department            String
  showroomId            String?            @map("showroom_id")
  salary                Decimal            @db.Decimal(12, 2)
  joiningDate           DateTime           @map("joining_date")
  passwordHash          String             @map("password_hash")
  isActive              Boolean            @default(true) @map("is_active")
  performanceScore      Decimal            @default(0) @db.Decimal(5, 2) @map("performance_score")
  createdAt             DateTime           @default(now()) @map("created_at")
  showroom              Showroom?          @relation("EmployeeShowroom", fields: [showroomId], references: [id], onDelete: SetNull)
  managedShowroom       Showroom?          @relation("ShowroomManager")
  targets               EmployeeTarget[]
  attendance            Attendance[]
  leaveRequests         LeaveRequest[]     @relation("EmployeeLeaveRequests")
  approvedLeaveRequests LeaveRequest[]     @relation("LeaveApprover")
  leaveBalances         LeaveBalance[]
  assignedLeads         Lead[]
  leadInteractions      LeadInteraction[]
  supportTickets        SupportTicket[]    @relation("AssignedTickets")
  ticketEscalatedBy     TicketEscalation[] @relation("TicketEscalatedBy")
  ticketEscalatedTo     TicketEscalation[] @relation("TicketEscalatedTo")
  cannedResponses       CannedResponse[]
  kbArticles            KbArticle[]
  purchases             Purchase[]
  testDrives            TestDriveBooking[]
  serviceBookings       ServiceBooking[]

  @@index([role])
  @@index([department])
  @@index([showroomId])
  @@index([isActive])
  @@map("employees")
}

model EmployeeTarget {
  id               String   @id @default(cuid())
  employeeId       String   @map("employee_id")
  month            Int
  year             Int
  salesTarget      Int      @map("sales_target")
  revenueTarget    Decimal  @db.Decimal(14, 2) @map("revenue_target")
  salesAchieved    Int      @default(0) @map("sales_achieved")
  revenueAchieved  Decimal  @default(0) @db.Decimal(14, 2) @map("revenue_achieved")
  commissionEarned Decimal  @default(0) @db.Decimal(12, 2) @map("commission_earned")
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@map("employee_targets")
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String           @map("employee_id")
  date       DateTime
  checkIn    DateTime?        @map("check_in")
  checkOut   DateTime?        @map("check_out")
  status     AttendanceStatus
  createdAt  DateTime         @default(now()) @map("created_at")
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@map("attendance")
}

model LeaveRequest {
  id           String        @id @default(cuid())
  employeeId   String        @map("employee_id")
  leaveType    LeaveType     @map("leave_type")
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  reason       String
  status       RequestStatus @default(Pending)
  approvedById String?       @map("approved_by")
  createdAt    DateTime      @default(now()) @map("created_at")
  employee     Employee      @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy   Employee?     @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([approvedById])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  year        Int
  earnedTotal Int      @map("earned_total")
  earnedUsed  Int      @default(0) @map("earned_used")
  sickTotal   Int      @map("sick_total")
  sickUsed    Int      @default(0) @map("sick_used")
  casualTotal Int      @map("casual_total")
  casualUsed  Int      @default(0) @map("casual_used")
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
  @@map("leave_balance")
}

model Lead {
  id           String            @id @default(cuid())
  customerId   String?           @map("customer_id")
  assignedToId String?           @map("assigned_to")
  carModelId   String?           @map("car_model_id")
  source       LeadSource
  budgetMin    Decimal           @db.Decimal(12, 2) @map("budget_min")
  budgetMax    Decimal           @db.Decimal(12, 2) @map("budget_max")
  stage        LeadStage         @default(Inquiry)
  priority     LeadPriority      @default(Warm)
  notes        String
  followUpDate DateTime?         @map("follow_up_date")
  score        Int               @default(0)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo   Employee?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  carModel     CarModel?         @relation(fields: [carModelId], references: [id], onDelete: SetNull)
  interactions LeadInteraction[]

  @@index([customerId])
  @@index([assignedToId])
  @@index([carModelId])
  @@index([stage])
  @@index([priority])
  @@index([followUpDate])
  @@index([score])
  @@map("leads")
}

model LeadInteraction {
  id              String          @id @default(cuid())
  leadId          String          @map("lead_id")
  employeeId      String          @map("employee_id")
  interactionType InteractionType @map("interaction_type")
  notes           String
  nextAction      String          @map("next_action")
  createdAt       DateTime        @default(now()) @map("created_at")
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id])

  @@index([leadId])
  @@index([employeeId])
  @@index([interactionType])
  @@index([createdAt])
  @@map("lead_interactions")
}

model SupportTicket {
  id           String             @id @default(cuid())
  customerId   String             @map("customer_id")
  assignedToId String?            @map("assigned_to")
  ticketNumber String             @unique @map("ticket_number")
  issueType    TicketIssueType    @map("issue_type")
  priority     TicketPriority
  status       TicketStatus       @default(Open)
  sentiment    Sentiment          @default(Neutral)
  channel      TicketChannel
  slaDeadline  DateTime           @map("sla_deadline")
  resolvedAt   DateTime?          @map("resolved_at")
  csatScore    Int?               @map("csat_score")
  createdAt    DateTime           @default(now()) @map("created_at")
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTo   Employee?          @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]
  escalations  TicketEscalation[]

  @@index([customerId])
  @@index([assignedToId])
  @@index([priority])
  @@index([status])
  @@index([sentiment])
  @@index([channel])
  @@index([slaDeadline])
  @@index([createdAt])
  @@map("support_tickets")
}

model TicketMessage {
  id             String        @id @default(cuid())
  ticketId       String        @map("ticket_id")
  senderId       String        @map("sender_id")
  senderType     SenderType    @map("sender_type")
  message        String
  isInternalNote Boolean       @default(false) @map("is_internal_note")
  attachments    String[]
  createdAt      DateTime      @default(now()) @map("created_at")
  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@index([senderType])
  @@index([createdAt])
  @@map("ticket_messages")
}

model TicketEscalation {
  id            String        @id @default(cuid())
  ticketId      String        @map("ticket_id")
  escalatedById String        @map("escalated_by")
  escalatedToId String        @map("escalated_to")
  reason        String
  level         Int
  createdAt     DateTime      @default(now()) @map("created_at")
  resolvedAt    DateTime?     @map("resolved_at")
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  escalatedBy   Employee      @relation("TicketEscalatedBy", fields: [escalatedById], references: [id])
  escalatedTo   Employee      @relation("TicketEscalatedTo", fields: [escalatedToId], references: [id])

  @@index([ticketId])
  @@index([escalatedById])
  @@index([escalatedToId])
  @@index([level])
  @@index([createdAt])
  @@map("ticket_escalations")
}

model CannedResponse {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   Employee @relation(fields: [createdById], references: [id])

  @@index([category])
  @@index([createdById])
  @@map("canned_responses")
}

model KbArticle {
  id          String     @id @default(cuid())
  title       String
  content     String
  category    KbCategory
  isPublic    Boolean    @default(true) @map("is_public")
  useCount    Int        @default(0) @map("use_count")
  createdById String     @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  createdBy   Employee   @relation(fields: [createdById], references: [id])

  @@index([category])
  @@index([isPublic])
  @@index([useCount])
  @@map("kb_articles")
}

model JobOpening {
  id            String           @id @default(cuid())
  title         String
  department    String
  location      String
  jobType       JobType          @map("job_type")
  description   String
  requirements  String
  salaryRange   String           @map("salary_range")
  openingsCount Int              @map("openings_count")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  applications  JobApplication[]

  @@index([department])
  @@index([location])
  @@index([jobType])
  @@index([isActive])
  @@map("job_openings")
}

model JobApplication {
  id              String            @id @default(cuid())
  jobOpeningId    String            @map("job_opening_id")
  applicantName   String            @map("applicant_name")
  email           String
  phone           String
  resumeUrl       String            @map("resume_url")
  coverLetter     String            @map("cover_letter")
  applicationId   String            @unique @map("application_id")
  status          ApplicationStatus @default(Applied)
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  jobOpening      JobOpening        @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)

  @@index([jobOpeningId])
  @@index([status])
  @@index([createdAt])
  @@map("job_applications")
}

model DailySalesSummary {
  id         String   @id @default(cuid())
  date       DateTime
  showroomId String   @map("showroom_id")
  carsSold   Int      @default(0) @map("cars_sold")
  revenue    Decimal  @default(0) @db.Decimal(14, 2)
  testDrives Int      @default(0) @map("test_drives")
  newLeads   Int      @default(0) @map("new_leads")
  createdAt  DateTime @default(now()) @map("created_at")
  showroom   Showroom @relation(fields: [showroomId], references: [id], onDelete: Cascade)

  @@unique([date, showroomId])
  @@index([date])
  @@index([showroomId])
  @@map("daily_sales_summary")
}

model MonthlyRevenueSummary {
  id            String   @id @default(cuid())
  month         Int
  year          Int
  showroomId    String   @map("showroom_id")
  totalRevenue  Decimal  @default(0) @db.Decimal(14, 2) @map("total_revenue")
  totalExpenses Decimal  @default(0) @db.Decimal(14, 2) @map("total_expenses")
  grossProfit   Decimal  @default(0) @db.Decimal(14, 2) @map("gross_profit")
  carsSold      Int      @default(0) @map("cars_sold")
  newCustomers  Int      @default(0) @map("new_customers")
  avgDealSize   Decimal  @default(0) @db.Decimal(12, 2) @map("avg_deal_size")
  showroom      Showroom @relation(fields: [showroomId], references: [id], onDelete: Cascade)

  @@unique([month, year, showroomId])
  @@index([month, year])
  @@index([showroomId])
  @@map("monthly_revenue_summary")
}

model CustomerActivityLog {
  id         String             @id @default(cuid())
  customerId String             @map("customer_id")
  actionType ActivityActionType @map("action_type")
  metadata   Json
  ipAddress  String             @map("ip_address")
  createdAt  DateTime           @default(now()) @map("created_at")
  customer   Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([actionType])
  @@index([createdAt])
  @@map("customer_activity_log")
}

model PipelineLog {
  id               String         @id @default(cuid())
  pipelineName     String         @map("pipeline_name")
  status           PipelineStatus
  recordsProcessed Int            @default(0) @map("records_processed")
  startedAt        DateTime       @map("started_at")
  completedAt      DateTime?      @map("completed_at")
  errorMsg         String?        @map("error_msg")

  @@index([pipelineName])
  @@index([status])
  @@index([startedAt])
  @@map("pipeline_logs")
}

model Notification {
  id            String        @id @default(cuid())
  recipientId   String        @map("recipient_id")
  recipientType RecipientType @map("recipient_type")
  title         String
  message       String
  type          String
  isRead        Boolean       @default(false) @map("is_read")
  link          String?
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([recipientId, recipientType])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Offer {
  id              String    @id @default(cuid())
  title           String
  description     String
  discountPercent Decimal   @db.Decimal(5, 2) @map("discount_percent")
  carModelId      String?   @map("car_model_id")
  validFrom       DateTime  @map("valid_from")
  validTill       DateTime  @map("valid_till")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  carModel        CarModel? @relation(fields: [carModelId], references: [id], onDelete: SetNull)

  @@index([carModelId])
  @@index([isActive])
  @@index([validFrom, validTill])
  @@map("offers")
}

model Wishlist {
  id                String    @id @default(cuid())
  customerId        String    @map("customer_id")
  carModelId        String    @map("car_model_id")
  priceAlertEnabled Boolean   @default(false) @map("price_alert_enabled")
  createdAt         DateTime  @default(now()) @map("created_at")
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  carModel          CarModel  @relation(fields: [carModelId], references: [id], onDelete: Cascade)

  @@unique([customerId, carModelId])
  @@index([customerId])
  @@index([carModelId])
  @@map("wishlists")
}
